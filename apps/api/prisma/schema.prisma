generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Crawl {
  id              Int      @id @default(autoincrement())
  url             String
  html            String
  screenshotPath  String?
  title           String?
  metaDescription String?
  createdAt       DateTime @default(now())
}
