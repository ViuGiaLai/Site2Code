APP_NAME=Site2Code
APP_VERSION=1.0.0

HOST=127.0.0.1
PORT=8765

NODE_ENV=development

APP_URL=http://localhost:3000
API_URL=http://localhost:8765

# ==========================================================
# DATABASE
# ==========================================================

DATABASE_URL=
# PostgreSQL
# Lưu:
