# Hero
# Card
# Footer
# Pricing
# FAQ

ENABLE_LAYOUT_ANALYZER=true
# Grid
# Flex
# Responsive

ENABLE_COLOR_ANALYZER=true

ENABLE_FONT_ANALYZER=true

ENABLE_SEO_ANALYZER=true

ENABLE_ACCESSIBILITY_ANALYZER=true

