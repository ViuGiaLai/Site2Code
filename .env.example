# ==========================================================
# PIPELINE AI ROUTING — FREE tier only
# ==========================================================
AI_ANALYZE_PROVIDER=gemini
AI_GENERATE_PROVIDER=gemini
AI_REVIEW_PROVIDER=gemini
AI_OPTIMIZE_PROVIDER=cerebras
AI_SECURITY_PROVIDER=gemini
AI_MAX_RETRIES=1
AI_MAX_TOKENS=8192
AI_TEMPERATURE=0.2
AI_REQUEST_TIMEOUT_MS=120000
AI_PAYLOAD_MAX_CHARS=100000
AI_PIPELINE_FAST=true

# Performance (crawl + skills)
CRAWL_TIMEOUT_MS=25000
CRAWL_SETTLE_MS=800
CRAWL_SCREENSHOT=false
SKILLS_MAX_CHARS=32000
SKILLS_MAX_CHARS_ANALYZE=12000
SKILLS_MAX_CHARS_GENERATE=28000
SKILLS_MAX_CHARS_REVIEW=8000
SKILLS_MAX_CHARS_OPTIMIZE=8000
SKILLS_MAX_CHARS_SECURITY=6000

# ==========================================================
# DEFAULT (LLM_MODE: cloud | local)
# ==========================================================
LLM_MODE=cloud


