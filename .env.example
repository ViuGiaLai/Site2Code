SCREENSHOT_DIR=screenshots

EXPORT_DIR=exports

TEMP_DIR=temp

# ==========================================================
# PLAYWRIGHT
# ==========================================================

PLAYWRIGHT_BROWSER=chromium

PLAYWRIGHT_HEADLESS=true

PLAYWRIGHT_TIMEOUT=60000

USER_AGENT=Site2CodeBot

ENABLE_SCREENSHOT=true

ENABLE_MOBILE_SCREENSHOT=true

ENABLE_TABLET_SCREENSHOT=true

# ==========================================================
# WEBSITE ANALYZER
# ==========================================================

ENABLE_HTML_ANALYZER=true
# Phân tích HTML

ENABLE_CSS_ANALYZER=true
# Phân tích CSS

ENABLE_JS_ANALYZER=true
# Phân tích JavaScript

ENABLE_DOM_TREE=true
# DOM Tree

ENABLE_COMPONENT_DETECTOR=true
